{
  "description": "Context Guard hooks — work state preservation + context security scanning",
  "hooks": {
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/compact-guard-pre.sh\"",
            "statusMessage": "Saving work state..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/security-pre-tool.sh\"",
            "statusMessage": "Security scan..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/security-post-tool.sh\"",
            "statusMessage": "Scanning output..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/compact-guard-stop.sh\"",
            "statusMessage": "Saving session bookmark..."
          }
        ]
      }
    ]
  }
}
